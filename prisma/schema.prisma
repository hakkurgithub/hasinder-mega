generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String  @id @default(uuid())
  name     String
  taxNo    String? @unique
  role     String? @default("USER")
  phone    String?
  iban     String?
  email    String  @unique
  password String
  balance  Float   @default(0)
  isAdmin  Boolean @default(false)
  status   String  @default("BEKLEMEDE")
  createdAt DateTime @default(now())
}

model Demand {
  id          String   @id @default(uuid())
  title       String
  amount      Float    @default(0)
  status      String   @default("BEKLEMEDE")
  description String?
  images      String[]
  creatorId   String
  createdAt   DateTime @default(now())
}

model Mediation {
  id              String   @id @default(uuid())
  status          String   @default("BEKLEMEDE")
  amount          Float    @default(0)
  commissionAmount Float   @default(0)
  mediatorId      String
  demandId        String
  sellerId        String
  createdAt       DateTime @default(now())
}

model LogisticsRoute {
  id           String   @id @default(uuid())
  origin       String
  destination  String
  vehicleType  String
  capacity     String
  targetPrice  Float?
  status       String   @default("AKTIF")
  createdAt    DateTime @default(now())
}

model Haber {
  id        String   @id @default(uuid())
  title     String
  content   String?
  image     String?
  createdAt DateTime @default(now())
}
