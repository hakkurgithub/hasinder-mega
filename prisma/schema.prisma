generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  name        String
  taxNo       String
  sector      String
  title       String
  email       String   @unique
  password    String
  balance     Float    @default(0)
  isAdmin     Boolean  @default(false)
  status      String
  tier        String
  createdAt   DateTime @default(now())
  AdminLogs   AdminLog[]
}

model AdminLog {
  id        String   @id @default(cuid())
  action    String
  details   String?
  createdAt DateTime @default(now())
  adminId   String
  Admin     User     @relation(fields: [adminId], references: [id])
}
