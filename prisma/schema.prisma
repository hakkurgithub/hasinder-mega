generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id          String   @id @default(uuid())
  name        String
  taxNo       String
  sector      String
  title       String
  email       String   @unique
  password    String
  balance     Float    @default(0)
  isAdmin     Boolean  @default(false)
  status      String
  tier        String
  iban        String?
  createdAt   DateTime @default(now())
  AdminLogs   AdminLog[]
  MediationsAsMediator Mediation[] @relation("MediatorRelation")
}

model Demand {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String   @default("BEKLEMEDE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  Mediations  Mediation[]
}

model Mediation {
  id          String   @id @default(uuid())
  status      String   @default("BEKLEMEDE")
  amount      Float    @default(0)
  mediatorId  String
  demandId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  mediator    User     @relation("MediatorRelation", fields: [mediatorId], references: [id])
  demand      Demand   @relation(fields: [demandId], references: [id])
}

model AdminLog {
  id        String   @id @default(cuid())
  action    String
  details   String?
  createdAt DateTime @default(now())
  adminId   String
  Admin     User     @relation(fields: [adminId], references: [id])
}
