generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String      @id @default(uuid())
  name                  String
  taxNo                 String?
  sector                String?
  title                 String?
  email                 String      @unique
  password              String
  balance               Float       @default(0)
  isAdmin               Boolean     @default(false)
  status                String      @default("AKTIF")
  tier                  String      @default("STANDART")
  iban                  String?
  createdAt             DateTime    @default(now())
  AdminLogs             AdminLog[]
  MediationsAsMediator  Mediation[] @relation("MediatorRelation")
  Demands               Demand[]    @relation("UserDemands")
}

model Demand {
  id          String      @id @default(uuid())
  title       String
  description String?
  amount      Float       @default(0)
  sector      String?
  status      String      @default("BEKLEMEDE")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  creatorId   String
  creator     User        @relation("UserDemands", fields: [creatorId], references: [id])
  Mediations  Mediation[]
}

model Mediation {
  id          String   @id @default(uuid())
  status      String   @default("BEKLEMEDE")
  amount      Float    @default(0)
  mediatorId  String
  demandId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  mediator    User     @relation("MediatorRelation", fields: [mediatorId], references: [id])
  demand      Demand   @relation(fields: [demandId], references: [id])
}

model AdminLog {
  id        String   @id @default(cuid())
  action    String
  details   String?
  createdAt DateTime @default(now())
  adminId   String
  Admin     User     @relation(fields: [adminId], references: [id])
}

model Haber {
  id        String   @id @default(uuid())
  title     String
  content   String?
  image     String?   // Haber görseli için eklendi
  createdAt DateTime @default(now())
}
